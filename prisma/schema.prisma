// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Movie{
  id                String  @id @default(cuid()) 
  name              String
  releaseyear       Int 
  duration          Int
  genre             String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  trailerURL        String
  posterURl         String?

 directors          Director[]
 actors             Actors[]

 status             Status  @default(PENDING)
 createrId          String
 creator            User     @relation(fields: [createrId], references: [id])
}

model Actors {
  id                  String    @id @default(cuid())
  name                String
  age                 Int
  about               String 
  imageURL            String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  status              Status  @default(PENDING)
  createrId           String
  creator             User     @relation(fields: [createrId], references: [id])

  movies              Movie[]
}

model Director{
  id                  String    @id @default(cuid())
  name                String
  age                 Int 
  about               String 
  imageURL            String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  status              Status  @default(PENDING)
  createrId           String
  creator             User     @relation(fields: [createrId], references: [id])

  movies              Movie[]
}

enum Status {
  PENDING
  APPROVED
  REJECTED
}

enum Role{
  ADMIN
  EDITOR
  VIEWER
}

model User{
  id                  String    @id @default(cuid())
  username            String   @unique 
  email               String  @unique 
  password            String 
  role                Role    @default(VIEWER)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  createdMovies       Movie[]
  createdActors       Actors[]
  createdDirectors   Director[]

  @@map("users")
}
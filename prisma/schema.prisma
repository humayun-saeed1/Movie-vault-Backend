// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Movie{
  id                String  @id @default(cuid()) 
  name              String
  releaseyear       Int 
  duration          Int
  genre             String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  trailerURL        String
  posterURl         String?

 directors          Director[]
 actors             Actors[]

 createrId          String
 creator            User     @relation(fields: [createrId], references: [id])

 reviews     Review[]
 watchlist   Watchlist[]
 favourites  Favourite[]
}

model Actors {
  id                  String    @id @default(cuid())
  name                String
  age                 Int
  about               String 
  imageURL            String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  createrId           String
  creator             User     @relation(fields: [createrId], references: [id])

  movies              Movie[]
}

model Director{
  id                  String    @id @default(cuid())
  name                String
  age                 Int 
  about               String 
  imageURL            String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  createrId           String
  creator             User     @relation(fields: [createrId], references: [id])

  movies              Movie[]
}


enum Role{
  ADMIN
  EDITOR
  VIEWER
}

model User{
  id                  String    @id @default(cuid())
  username            String   @unique 
  email               String  @unique 
  password            String 
  role                Role    @default(VIEWER)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt


  createdMovies       Movie[]
  createdActors       Actors[]
  createdDirectors   Director[]

  reviews          Review[]
  watchlist        Watchlist[]
  favourites       Favourite[]

  @@map("users")
}

model Review {
  id        String   @id @default(cuid())
  rating    Int      // e.g., 1 to 10 stars
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  movieId   String
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model Watchlist {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  movieId   String
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)

  // Ensures a user can't add the same movie to their watchlist twice
  @@unique([userId, movieId])
  @@map("watchlists")
}

model Favourite {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  movieId   String
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)

  // Ensures a user can't favourite the exact same movie twice
  @@unique([userId, movieId])
  @@map("favourites")
}